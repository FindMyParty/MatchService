PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5434/match
RABBITMQ_URL=amqp://guest:guest@localhost:5672
NODE_ENV=development
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=
REDIS_URL=redis://localhost:6379
REDIS_TTL=86400

# RabbitMQ — filas e exchanges (valores abaixo são os padrões)
RABBITMQ_PROFILE_EXCHANGE=profile.events
RABBITMQ_PROFILE_QUEUE=match-service.profile.profile
RABBITMQ_PROFILE_BINDING_KEY=profile.profile.*

RABBITMQ_SWIPE_EXCHANGE=match
RABBITMQ_SWIPE_QUEUE=match-service.match.swipe
RABBITMQ_SWIPE_BINDING_KEY=match.swipe.*

RABBITMQ_SUGGESTION_EXCHANGE=suggestion
RABBITMQ_SUGGESTION_QUEUE=match-service.discovery.suggestion
RABBITMQ_SUGGESTION_BINDING_KEY=discovery.suggestion.*
